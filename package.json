{
  "name": "router-uri-convert",
  "version": "2.0.2",
  "description": "convert uri-template replace :varname with {+varname} to make it RFC 6570 compatible",
  "keywords": [
    "endpoint",
    "express",
    "litejs",
    "rfc 6570",
    "rfc6570",
    "router",
    "template",
    "uri",
    "uri template",
    "uri-template",
    "url",
    "url template",
    "url-template"
  ],
  "homepage": "https://github.com/bluelovers/ws-rest/tree/master/packages/router-uri#readme",
  "bugs": {
    "url": "https://github.com/bluelovers/ws-rest/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bluelovers/ws-rest.git",
    "directory": "packages/router-uri"
  },
  "license": "ISC",
  "author": "",
  "main": "index.js",
  "files": [
    "parser.d.ts",
    "parser.js.map",
    "parser.js",
    "docs/*",
    "CHANGELOG.md",
    "index.d.ts",
    "index.js.map",
    "index.js"
  ],
  "directories": {
    "docs": "docs"
  },
  "scripts": {
    "pretest": "tsc",
    "test": "node --run test:jest --",
    "test:jest": "vitest run --no-watch",
    "test:jest:coverage": "node --run test:jest -- --coverage",
    "test:jest:snapshot": "pnpm run test:jest -- -u",
    "test:snapshot": "pnpm run pretest && vitest run -u --no-watch",
    "test:tsd": "ynpx tsd",
    "npm:publish": "npm publish",
    "npm:publish:bump": "node --run version:bump && npm publish",
    "npm:publish:bump:major": "node --run version:bump:major && npm publish",
    "npm:publish:bump:minor": "node --run version:bump:minor && npm publish",
    "npm:publish:bump:patch": "node --run version:bump:patch && npm publish",
    "npm:publish:bump:prerelease": "node --run version:bump:prerelease && npm publish",
    "npm:publish:lerna": "lerna publish --yes",
    "preversion": "pnpm run test & echo current not support all test, will ignore failed when publish",
    "version": "echo version",
    "version:bump": "yarn-tool version",
    "version:bump:major": "node --run version:bump -- --bump major",
    "version:bump:minor": "node --run version:bump -- --bump minor",
    "version:bump:patch": "node --run version:bump -- --bump patch",
    "version:bump:prerelease": "node --run version:bump -- --bump prerelease",
    "prepublish:lockfile": "npx sync-lockfile .",
    "prepublishOnly": "pnpm run preversion",
    "prepublishOnly_": "pnpm run ncu && pnpm run sort-package-json && pnpm run test",
    "postpublish": "pnpm run postpublish:changelog && pnpm run postpublish:git:commit && pnpm run postpublish:git:tag && pnpm run postpublish:git:push",
    "postpublish_": "git commit -m \"chore(release): publish\" .",
    "postpublish:changelog": "ynpx --quiet @yarn-tool/changelog && git add ./CHANGELOG.md",
    "postpublish:git:commit": "git add ./test/__file_snapshots__ & git commit -m \"chore(release): publish\" . & echo postpublish:git:commit",
    "postpublish:git:push": "git push --follow-tags",
    "postpublish:git:tag": "ynpx --quiet @yarn-tool/tag",
    "ncu": "yarn-tool ncu -u",
    "sort-package-json": "yarn-tool sort",
    "tsc:default": "tsc -p tsconfig.json",
    "tsc:esm": "tsc -p tsconfig.esm.json",
    "tsc:showConfig": "ynpx get-current-tsconfig -p"
  },
  "dependencies": {
    "execall2": "^2.0.26",
    "ts-type": "^3.0.13",
    "tslib": "^2.8.1",
    "uri-template-lite": "^23.4.0"
  },
  "devDependencies": {
    "@bluelovers/tsconfig": "^2.0.3",
    "@types/node": "^25.9.1",
    "@types/uri-template-lite": "^19.12.4",
    "upath2": "^3.1.23",
    "url-template": "^3.1.1",
    "vitest": "^4.1.7"
  },
  "gitHead": "07a0344f1db068fd821683a22d0a4952441c9ccb"
}
